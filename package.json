{
  "name": "lazy-imagen-openrouter",
  "version": "1.0.0",
  "description": "AI image generation tool using OpenRouter API with orchestrator mode",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"*.html\""
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.0.0",
    "sharp": "^0.35.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "image-generation",
    "openrouter",
    "ai"
  ],
  "license": "MIT",
  "private": true,
  "dependencies": {
    "pica": "^9.0.1"
  }
}
